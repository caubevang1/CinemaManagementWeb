# ── Database (MySQL) ──
DB_URL=jdbc:mysql://localhost:3307/cinemaweb?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=
DB_PASSWORD=

# ── Email (SMTP, vd Brevo) ──
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
# Địa chỉ hiển thị ở mục "From" (phải là sender đã verify), khác MAIL_USERNAME (login SMTP)
MAIL_FROM=

# ── JWT ──
JWT_SIGNER_KEY=

# ── VNPay ──
VNPAY_SECRET_KEY=
VNPAY_TMN_CODE=
VNPAY_RETURN_URL=http://localhost:8080/api/payment/payment_info

# ── TMDB ──
TMDB_KEY=

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CORS (origin của frontend, nhiều origin ngăn cách bằng dấu phẩy) ──
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Tuỳ chọn: chỉ cần khi KHÔNG dùng giá trị mặc định ──
# REDIS_HOST=localhost
# REDIS_PORT=6379
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD=guest
